{
  "name": "hacker-dojo-grant-ops",
  "version": "0.1.0",
  "private": true,
  "description": "Hacker Dojo Grant Operations Center - Web App",
  "scripts": {
    "dev": "cd frontend && ../node_modules/.bin/next dev",
    "predev": "bash ./scripts/ensure-better-sqlite3.sh",
    "build": "cd frontend && node -e \"require('fs').rmSync('.next', { recursive: true, force: true })\" && ../node_modules/.bin/next build",
    "prebuild": "bash ./scripts/ensure-better-sqlite3.sh",
    "start": "cd frontend && PORT=3000 HOSTNAME=0.0.0.0 ../node_modules/.bin/next start",
    "start:verified": "bash scripts/setup-check.sh && cd frontend && PORT=3000 HOSTNAME=0.0.0.0 ../node_modules/.bin/next start",
    "prestart": "bash ./scripts/ensure-better-sqlite3.sh",
    "prelint": "bash ./scripts/ensure-better-sqlite3.sh",
    "lint": "eslint . --ext .ts,.tsx",
    "pretest": "bash ./scripts/ensure-better-sqlite3.sh",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:all": "vitest run && playwright test",
    "pretest:e2e": "bash ./scripts/ensure-better-sqlite3.sh",
    "test:e2e": "playwright test",
    "test:ui": "vitest --ui",
    "typecheck": "tsc --noEmit -p frontend/tsconfig.json",
    "typecheck:frontend": "tsc --noEmit -p frontend/tsconfig.json",
    "pretypecheck": "pnpm run build",
    "pretypecheck:frontend": "pnpm run build",
    "setup:check": "bash scripts/setup-check.sh",
    "verify:persistence-root": "tsx scripts/print-grant-ops-data-dir.ts && cd frontend && ../node_modules/.bin/tsx ../scripts/print-grant-ops-data-dir.ts",
    "verify": "./scripts/verify.sh"
  },
  "dependencies": {
    "better-sqlite3": "^12.4.1",
    "pdf-parse": "^1.1.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@next/eslint-plugin-next": "15.5.18",
    "@playwright/test": "^1.48.0",
    "@types/node": "^22.14.0",
    "@types/react": "19.2.15",
    "@typescript-eslint/eslint-plugin": "^8.30.1",
    "@typescript-eslint/parser": "^8.30.1",
    "@vitest/ui": "^2.1.9",
    "eslint": "^9.23.0",
    "eslint-config-next": "^15.2.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "jsdom": "^29.1.1",
    "next": "^15.2.0",
    "node-gyp": "^12.3.0",
    "playwright": "^1.48.0",
    "prettier": "^3.5.3",
    "tailwindcss": "^4.1.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^2.1.9"
  }
}