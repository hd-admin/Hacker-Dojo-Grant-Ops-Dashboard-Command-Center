{
  "name": "hacker-dojo-grant-ops",
  "version": "0.1.0",
  "private": true,
  "description": "Hacker Dojo Grant Operations Center - Desktop App",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "concurrently \"cd frontend && next dev\" \"wait-on http://localhost:3000 && cross-env ELECTRON_START_URL=http://localhost:3000 tsx electron/main.ts\"",
    "build": "cd frontend && next build && tsc -p ../electron/tsconfig.json",
    "start": "electron .",
    "lint": "cd frontend && next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:ui": "vitest --ui",
    "electron:build": "electron-builder --config electron-builder.yml",
    "typecheck": "cd frontend && tsc --noEmit"
  },
  "dependencies": {
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron-log": "^5.3.2",
    "electron-updater": "^6.3.9",
    "wait-on": "^7.2.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@types/node": "^22.14.0",
    "@types/react": "19.2.15",
    "@typescript-eslint/eslint-plugin": "^8.30.1",
    "@typescript-eslint/parser": "^8.30.1",
    "@vitest/ui": "^2.1.9",
    "electron": "^38.0.0",
    "electron-builder": "^25.1.8",
    "eslint": "^9.23.0",
    "eslint-config-next": "^15.2.0",
    "next": "^15.2.0",
    "playwright": "^1.48.0",
    "prettier": "^3.5.3",
    "tailwindcss": "^4.1.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^2.1.9"
  }
}
